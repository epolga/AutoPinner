# Copy to .env and fill in real values. .env is gitignored.

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or use AWS_PROFILE=<name> instead of explicit keys.
DDB_TABLE_NAME=CrossStitchItems

# --- Pinterest OAuth (mirrors Uploader/App.private.config keys) ---
# The OAuth flow shares the on-disk token file with Uploader; the path comes
# from cross-stitch-platform-docs/platform-config.json (pinterestTokenPath).
PinterestClientId=
PinterestClientSecret=
PinterestRedirectUri=

# --- Posting cadence & safety ---
POST_INTERVAL_SECONDS=300
DAILY_CAP=200
MAX_BATCH_PER_RUN=1

# --- URL building ---
BASE_URL=https://cross-stitch.com
IMAGE_BASE_URL=https://d2o1uvvg91z7o4.cloudfront.net
PHOTO_PREFIX=photos
# Optional template, e.g. {SiteBaseUrl}/Free-{CaptionSlug}-Charts.aspx style:
ALBUM_URL_TEMPLATE=
ENVIRONMENT_NAME=dev

# Optional fallback board if an album isn't in cross-stitch-platform-docs/data/AlbumBoards.csv:
DEFAULT_BOARD_ID=

# --- Email alerting (reuses Uploader's App.private.config naming) ---
# Leave SenderEmail/AdminEmail blank to disable email (stderr only).
SenderEmail=
AdminEmail=
SesConfigurationSetName=

ALERT_COOLDOWN_MINUTES=60
ALERT_CONSECUTIVE_FAILURE_THRESHOLD=5
ALERT_DAILY_SUMMARY_ENABLED=false
ALERT_DAILY_SUMMARY_HOUR_UTC=7
