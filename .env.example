# Copy to .env and fill in real values. .env is gitignored.

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or use AWS_PROFILE=<name> instead of explicit keys.
DDB_TABLE_NAME=CrossStitchItems

# --- Pinterest ---
PINTEREST_ACCESS_TOKEN=

# --- Posting cadence & safety ---
POST_INTERVAL_SECONDS=300
DAILY_CAP=200
MAX_BATCH_PER_RUN=1

# --- URL building ---
BASE_URL=https://cross-stitch.com
ENVIRONMENT_NAME=dev

# --- Board mapping ---
BOARDS_CSV_PATH=AlbumBoards.csv
# Optional fallback if an album isn't in the CSV:
DEFAULT_BOARD_ID=

# --- Email alerting ---
# Leave ALERT_EMAIL_TO/FROM blank to disable email (stderr only).
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_COOLDOWN_MINUTES=60
ALERT_CONSECUTIVE_FAILURE_THRESHOLD=5
ALERT_DAILY_SUMMARY_ENABLED=false
ALERT_DAILY_SUMMARY_HOUR_UTC=7
SES_CONFIGURATION_SET=

# SES (default) vs SMTP transport.
AUTO_PINNER_EMAIL_TRANSPORT=ses
# Required only if transport=smtp:
SES_SMTP_HOST=
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
